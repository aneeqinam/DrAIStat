Package: DrAIStat
Type: Package
Title: AI-Powered Statistical Analysis Tool for Research
Version: 3.0.0
Date: 2026-05-14
Authors@R: person(
    given   = "Aneeq",
    family  = "Inam",
    role    = c("aut", "cre"),
    email   = "a.inam@hbmsu.ac.ae",
    comment = c(ORCID = "0000-0001-7682-2244")
